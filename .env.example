# AudioMax Environment Configuration
# Note: All API keys are OPTIONAL. The app works in offline mode without them.

# API Keys for different AI providers (optional)
# Get Gemini API key from: https://ai.google.dev/
GEMINI_API_KEY=

# Get OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get Anthropic API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Server Port (optional, defaults to 3001)
PORT=3001

# Frontend URL for CORS (optional, defaults to allow all)
FRONTEND_URL=http://localhost:5173