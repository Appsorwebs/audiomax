{
  "name": "audiomax",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "AI-powered audio transcription and meeting analysis by AppsOrWebs Limited",
  "author": "AppsOrWebs Limited",
  "company": "AppsOrWebs Limited",
  "license": "Proprietary",
  "homepage": "https://appsorwebs.com",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:audio-formats": "vitest run tests/audio-formats.integration.test.ts",
    "android:dev": "npm run build && npx cap sync android && npx cap open android",
    "android:build": "npm run build && npx cap sync android",
    "ios:dev": "npm run build && npx cap sync ios && npx cap open ios",
    "ios:build": "npm run build && npx cap sync ios"
  },
  "dependencies": {
    "@google/genai": "^1.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "jsdom": "^29.1.1",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.9"
  }
}
